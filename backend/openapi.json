        ]
      }
    },
    "/health": {
      "get": {
        "operationId": "HealthController_getHealth",
        "parameters": [],
        "responses": {
          "200": {
            "description": "API is healthy"
          }
        },
        "summary": "Check API health status",
        "tags": [
          "health"
        ]
      }
    },
    "/health/database": {
      "get": {
        "operationId": "HealthController_getDatabaseStatus",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Database status retrieved"
          }
        },
        "summary": "Check Database connection status",
        "tags": [
          "health"
        ]
      }
    },
    "/auth/register": {
      "post": {
        "operationId": "AuthController_register",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "The user has been successfully registered.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request."
          }
        },
        "summary": "Register a new user",
        "tags": [
          "auth"
        ]
      }
    },
    "/auth/login": {
      "post": {
        "operationId": "AuthController_login",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The user has been successfully logged in.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponseDto"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized."
          }
        },
        "summary": "Login an existing user",
        "tags": [
          "auth"
        ]
      }
    },
    "/auth/me": {
      "get": {
        "operationId": "AuthController_getMe",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Return the current user profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserProfileResponseDto"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized."
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Get current user profile",
        "tags": [
          "auth"
        ]
      }
    },
    "/quiz/{id}": {
      "get": {
        "operationId": "QuizController_getQuiz",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "tags": [
          "Quiz"
        ]
      }
    },
    "/quiz/{id}/score": {
      "post": {
        "operationId": "QuizController_calculateScore",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CalculateQuizScoreDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": ""
          }
        },
        "tags": [
          "Quiz"
        ]
      }
    },
    "/users/me/parcours": {
      "patch": {
        "operationId": "UserController_updateParcours",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateParcoursDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Le parcours a été mis à jour."
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Mettre à jour le parcours de l'utilisateur",
        "tags": [
          "users"
        ]
      }
    },
    "/users/me/onboarding/complete": {
      "patch": {
        "operationId": "UserController_completeOnboarding",
        "parameters": [],
        "responses": {
          "200": {
            "description": "L'onboarding a été marqué comme terminé."
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Marquer l'onboarding comme complété",
        "tags": [
          "users"
        ]
      }
    },
    "/users/me/scores": {
      "get": {
        "operationId": "UserController_getScoreHistory",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Historique des scores récupéré avec succès",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ScoreHistoryResponseDto"
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Récupérer l'historique des scores carbone de l'utilisateur",
        "tags": [
          "users"
        ]
      }
    },
    "/parcours": {
      "get": {
        "operationId": "ParcoursController_getAllParcours",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Liste des parcours",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ParcoursDto"
                  }
                }
              }
            }
          }
        },
        "summary": "Récupérer la liste des parcours disponibles",
        "tags": [
          "parcours"
        ]
      }
    }
  },
  "info": {
    "title": "Projet-AGL API",
    "description": "The API documentation for Projet-AGL backend",
    "version": "1.0",
    "contact": {}
  },
  "tags": [
    {
      "name": "auth",
      "description": ""
    },
    {
      "name": "health",
      "description": ""
    }
  ],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "The email of the user",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "description": "The password of the user (min 6 characters)",
            "example": "password123",
            "minLength": 6
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "UserDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "dc147d80-0ee4-42db-84f0-4150fa0593f3"
          },
          "email": {
            "type": "string",
            "example": "user@example.com"
          },
          "email_confirmed_at": {
            "type": "string"
          },
          "last_sign_in_at": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "email"
        ]
      },
      "SessionDto": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string"
          },
          "token_type": {
            "type": "string",
            "example": "bearer"
          },
          "expires_in": {
            "type": "number",
            "example": 3600
          },
          "expires_at": {
            "type": "number"
          }
        },
        "required": [
          "access_token",
          "token_type",
          "expires_in",
          "expires_at"
        ]
      },
      "AuthResponseDto": {
        "type": "object",
        "properties": {
          "user": {
            "$ref": "#/components/schemas/UserDto"
          },
          "session": {
            "$ref": "#/components/schemas/SessionDto"
          }
        },
        "required": [
          "user"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "The email of the user",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "description": "The password of the user",
            "example": "password123"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "ParcoursDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "de879435-0ee4-42db-84f0-4150fa0593f3"
          },
          "slug": {
            "type": "string",
            "example": "decouverte"
          },
          "name": {
            "type": "string",
            "example": "DÉCOUVERTE"
          },
          "description": {
            "type": "string",
            "example": "L’essentiel rapidement. Comprendre mon score sans surcharge avec des défis simples."
          },
          "defis_per_period": {
            "type": "number",
            "example": 1
          },
          "quizz_per_period": {
            "type": "number",
            "example": 1
          },
          "period_type": {
            "type": "string",
            "example": "WEEK"
          }
        },
        "required": [
          "id",
          "slug",
          "name",
          "description",
          "defis_per_period",
          "quizz_per_period",
          "period_type"
        ]
      },
      "UserProfileResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "dc147d80-0ee4-42db-84f0-4150fa0593f3"
          },
          "email": {
            "type": "string",
            "example": "user@example.com"
          },
          "firstName": {
            "type": "object",
            "nullable": true,
            "example": "Jean"
          },
          "lastName": {
            "type": "object",
            "nullable": true,
            "example": "Dupont"
          },
          "feuilles": {
            "type": "number",
            "example": 450
          },
          "niveau": {
            "type": "number",
            "example": 5
          },
          "onboardingCompleted": {
            "type": "boolean",
            "example": true
          },
          "parcours": {
            "nullable": true,
            "allOf": [
              {
                "$ref": "#/components/schemas/ParcoursDto"
              }
            ]
          }
        },
        "required": [
          "id",
          "email",
          "feuilles",
          "niveau",
          "onboardingCompleted"
        ]
      },
      "CalculateQuizScoreDto": {
        "type": "object",
        "properties": {
          "answers": {
            "type": "object",
            "description": "Map des reponses du quiz. Cle = questionId, valeur = string | number | string[]",
            "example": {
              "q1": "voiture_diesel_essence",
              "q2": "50_100",
              "q3": [
                "voiture",
                "train"
              ],
              "q4": 2,
              "q4b": "moyen",
              "q5": "1d"
            }
          }
        },
        "required": [
          "answers"
        ]
      },
      "UpdateParcoursDto": {
        "type": "object",
        "properties": {
          "parcoursId": {
            "type": "string",
            "description": "ID du parcours choisi",
            "example": "d290f1ee-6c54-4b01-90e6-d701748f0851"
          }
        },
        "required": [
          "parcoursId"
        ]
      },
      "ScoreHistoryResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "ID de l'entrée d'historique",
            "example": "f839d-21cd-40b9-a212-32a2f81903fa"
          },
          "score": {
            "type": "number",
            "description": "Score carbone obtenu",
            "example": 1450.5
          },
          "created_at": {
            "format": "date-time",
            "type": "string",
            "description": "Date de l'enregistrement",
            "example": "2026-03-16T18:30:00.000Z"
          }
        },
        "required": [
          "id",
          "score",
          "created_at"
        ]
      }
    }
  }
}