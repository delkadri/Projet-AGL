        "operationId": "ChatController_listMessages",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "schema": {
              "minimum": 1,
              "maximum": 100,
              "default": 50,
              "example": 50,
              "type": "number"
            }
          },
          {
            "name": "before",
            "required": false,
            "in": "query",
            "description": "Curseur de pagination : ISO date — renvoie les messages strictement antérieurs.",
            "schema": {
              "example": "2026-05-11T12:34:56.000Z",
              "type": "string"
            }
          }
        ],
