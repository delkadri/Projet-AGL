  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "The email of the user",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "description": "The password of the user (min 6 characters)",
            "example": "password123",
            "minLength": 6
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "UserDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "dc147d80-0ee4-42db-84f0-4150fa0593f3"
          },
          "email": {
            "type": "string",
            "example": "user@example.com"
          },
          "email_confirmed_at": {
            "type": "string"
          },
          "last_sign_in_at": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "email"
        ]
      },
      "SessionDto": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string"
          },
          "token_type": {
            "type": "string",
            "example": "bearer"
          },
          "expires_in": {
            "type": "number",
            "example": 3600
          },
          "expires_at": {
            "type": "number"
          }
        },
        "required": [
          "access_token",
          "token_type",
          "expires_in",
          "expires_at"
        ]
      },
      "AuthResponseDto": {
        "type": "object",
        "properties": {
          "user": {
            "$ref": "#/components/schemas/UserDto"
          },
          "session": {
            "$ref": "#/components/schemas/SessionDto"
          }
        },
        "required": [
          "user"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "The email of the user",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "description": "The password of the user",
            "example": "password123"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "ParcoursDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "de879435-0ee4-42db-84f0-4150fa0593f3"
          },
          "slug": {
            "type": "string",
            "example": "decouverte"
          },
          "name": {
            "type": "string",
            "example": "DÉCOUVERTE"
          },
          "description": {
            "type": "string",
            "example": "L’essentiel rapidement. Comprendre mon score sans surcharge avec des défis simples."
          },
          "defis_per_period": {
            "type": "number",
            "example": 1
          },
          "quizz_per_period": {
            "type": "number",
            "example": 1
          },
          "period_type": {
            "type": "string",
            "example": "WEEK"
          }
        },
        "required": [
          "id",
          "slug",
          "name",
          "description",
          "defis_per_period",
          "quizz_per_period",
          "period_type"
        ]
      },
      "UserProfileResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "dc147d80-0ee4-42db-84f0-4150fa0593f3"
          },
          "email": {
            "type": "string",
            "example": "user@example.com"
          },
          "firstName": {
            "type": "object",
            "nullable": true,
            "example": "Jean"
          },
          "lastName": {
            "type": "object",
            "nullable": true,
            "example": "Dupont"
