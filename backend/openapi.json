{
  "openapi": "3.0.0",
  "paths": {
    "/": {
      "get": {
        "operationId": "AppController_getHello",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "tags": [
          "App"
        ]
      }
    },
    "/health": {
      "get": {
        "operationId": "HealthController_getHealth",
        "parameters": [],
        "responses": {
          "200": {
            "description": "API is healthy"
          }
        },
        "summary": "Check API health status",
        "tags": [
          "health"
        ]
      }
    },
    "/health/supabase": {
      "get": {
        "operationId": "HealthController_getSupabaseStatus",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Supabase status retrieved"
          }
        },
        "summary": "Check Supabase connection status",
        "tags": [
          "health"
        ]
      }
    },
    "/auth/register": {
      "post": {
        "operationId": "AuthController_register",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "The user has been successfully registered.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request."
          }
        },
        "summary": "Register a new user",
        "tags": [
          "auth"
        ]
      }
    },
    "/auth/login": {
      "post": {
        "operationId": "AuthController_login",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The user has been successfully logged in.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponseDto"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized."
          }
        },
        "summary": "Login an existing user",
        "tags": [
          "auth"
        ]
      }
    },
    "/quiz/{id}": {
      "get": {
        "operationId": "QuizController_getQuiz",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "tags": [
          "Quiz"
        ]
      }
    },
    "/quiz/{id}/score": {
      "post": {
        "operationId": "QuizController_calculateScore",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CalculateQuizScoreDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": ""
          }
        },
        "tags": [
          "Quiz"
        ]
      }
    }
  },
  "info": {
    "title": "Projet-AGL API",
    "description": "The API documentation for Projet-AGL backend",
    "version": "1.0",
    "contact": {}
  },
  "tags": [
    {
      "name": "auth",
      "description": ""
    },
    {
      "name": "health",
      "description": ""
    }
  ],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "The email of the user",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "description": "The password of the user (min 6 characters)",
            "example": "password123",
            "minLength": 6
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "UserDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "dc147d80-0ee4-42db-84f0-4150fa0593f3"
          },
          "email": {
            "type": "string",
            "example": "user@example.com"
          },
          "email_confirmed_at": {
            "type": "string"
          },
          "last_sign_in_at": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "email"
        ]
      },
      "SessionDto": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string"
          },
          "token_type": {
            "type": "string",
            "example": "bearer"
          },
          "expires_in": {
            "type": "number",
            "example": 3600
          },
          "expires_at": {
            "type": "number"
          }
        },
        "required": [
          "access_token",
          "token_type",
          "expires_in",
          "expires_at"
        ]
      },
      "AuthResponseDto": {
        "type": "object",
        "properties": {
          "user": {
            "$ref": "#/components/schemas/UserDto"
          },
          "session": {
            "$ref": "#/components/schemas/SessionDto"
          }
        },
        "required": [
          "user"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "The email of the user",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "description": "The password of the user",
            "example": "password123"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "CalculateQuizScoreDto": {
        "type": "object",
        "properties": {
          "answers": {
            "type": "object",
            "description": "Map des reponses du quiz. Cle = questionId, valeur = string | number | string[]",
            "example": {
              "q1": "voiture_diesel_essence",
              "q2": "50_100",
              "q3": [
                "voiture",
                "train"
              ],
              "q4": 2,
              "q4b": "moyen",
              "q5": "1d"
            }
          }
        },
        "required": [
          "answers"
        ]
      }
    }
  }
}