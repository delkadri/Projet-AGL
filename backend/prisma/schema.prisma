generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model quizzes {
  id         String   @id
  name       String
  content    Json
  created_at DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
}

model users {
  id                          String                        @id @default(uuid())
  email                       String                        @unique
  first_name                  String?
  last_name                   String?
  feuilles                    Int                           @default(0)
  onboarding_completed        Boolean                       @default(false)
  parcours_id                 String?
  created_at                  DateTime                      @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at                  DateTime                      @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  group_challenge_completions group_challenge_completions[]
  group_members               group_members[]
  groups                      groups[]
  score_history               score_history[]
  user_challenges             user_challenges[]
  parcours                    parcours?                     @relation(fields: [parcours_id], references: [id])
}

model score_history {
  id           String   @id @default(uuid())
  user_id      String
  score        Float
  created_at   DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  json_answers Json?
  user         users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model parcours {
  id               String   @id @default(uuid())
  slug             String   @unique
  name             String
  description      String
  defis_per_period Int
  quizz_per_period Int
  period_type      String
  created_at       DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at       DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  challenges       challenges[]
  users            users[]
}

model challenges {
  id               String               @id @default(uuid())
  title            String
  description      String
  category         String
  frequency        challenge_frequency
  co2_saved_kg     Float
  feuilles         Int
  parcours_id      String?
  created_at       DateTime             @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at       DateTime             @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  group_challenges group_challenges[]
  user_challenges  user_challenges[]
  parcours         parcours?            @relation(fields: [parcours_id], references: [id])

  @@unique([title, parcours_id, frequency])
}

model user_challenges {
  id           String     @id @default(uuid())
  user_id      String
  challenge_id String
  completed_at DateTime?
  co2_saved_kg Float
  feuilles     Int
  created_at   DateTime   @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at   DateTime   @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  challenge    challenges @relation(fields: [challenge_id], references: [id], onDelete: Cascade)
  user         users      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, completed_at])
  @@index([challenge_id])
}

model levels {
  id                String   @id @default(uuid())
  level_number      Int      @unique
  required_feuilles Int      @unique
  created_at        DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at        DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
}

model group_challenge_completions {
  id                 String           @id
  group_challenge_id String
  user_id            String
  completed_at       DateTime         @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  group_challenges   group_challenges @relation(fields: [group_challenge_id], references: [id], onDelete: Cascade)
  users              users            @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([group_challenge_id, user_id])
}

model group_challenges {
  id                          String                        @id
  group_id                    String
  challenge_id                String
  week_start_at               DateTime                      @db.Timestamptz(6)
  week_end_at                 DateTime                      @db.Timestamptz(6)
  created_at                  DateTime                      @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  group_challenge_completions group_challenge_completions[]
  challenges                  challenges                    @relation(fields: [challenge_id], references: [id])
  groups                      groups                        @relation(fields: [group_id], references: [id], onDelete: Cascade)
}

model group_members {
  id        String   @id
  group_id  String
  user_id   String
  arbres    Int      @default(0)
  joined_at DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  groups    groups   @relation(fields: [group_id], references: [id], onDelete: Cascade)
  users     users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([group_id, user_id])
}

model groups {
  id                     String             @id
  name                   String
  description            String?
  is_public              Boolean            @default(true)
  invite_code            String             @unique
  admin_id               String
  status                 GroupStatus        @default(active)
  win_streak             Int                @default(0)
  last_streak_updated_at DateTime?          @db.Timestamptz(6)
  created_at             DateTime           @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at             DateTime           @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  group_challenges       group_challenges[]
  group_members          group_members[]
  users                  users              @relation(fields: [admin_id], references: [id], onDelete: Cascade)
}

enum GroupStatus {
  active
  inactive
}

enum challenge_frequency {
  daily
  weekly
  monthly
}
